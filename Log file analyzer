import re

# Generator to read large files line by line
def read_log_file(filename):
    try:
        with open(filename, "r") as file:
            for line in file:
                yield line.strip()
    except FileNotFoundError:
        print("Log file not found!")


# Analyze Logs
def analyze_logs(filename):
    error_codes = {}
    ip_addresses = set()
    timestamps = []

    # Regex Patterns
    ip_pattern = r"\b(?:\d{1,3}\.){3}\d{1,3}\b"
    error_pattern = r"ERROR\s+(\d+)"
    timestamp_pattern = r"\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}"

    for line in read_log_file(filename):

        # Extract IP
        ip_match = re.search(ip_pattern, line)
        if ip_match:
            ip_addresses.add(ip_match.group())

        # Extract Error Code
        error_match = re.search(error_pattern, line)
        if error_match:
            code = error_match.group(1)

            if code in error_codes:
                error_codes[code] += 1
            else:
                error_codes[code] = 1

        # Extract Timestamp
        time_match = re.search(timestamp_pattern, line)
        if time_match:
            timestamps.append(time_match.group())

    return error_codes, ip_addresses, timestamps


# Save Summary Report
def save_report(error_codes, ip_addresses, timestamps):
    with open("log_report.txt", "w") as file:
        file.write("===== LOG FILE SUMMARY =====\n\n")

        file.write("Error Codes:\n")
        for code, count in error_codes.items():
            file.write(f"Error {code}: {count} occurrence(s)\n")

        file.write("\nUnique IP Addresses:\n")
        for ip in ip_addresses:
            file.write(ip + "\n")

        file.write("\nTotal Unique IPs: ")
        file.write(str(len(ip_addresses)))

        file.write("\n\nTotal Timestamps Found: ")
        file.write(str(len(timestamps)))

    print("Report saved to log_report.txt")


# Main Program
filename = "server.log"

error_codes, ips, timestamps = analyze_logs(filename)

print("Error Codes:", error_codes)
print("Unique IPs:", len(ips))
print("Timestamps Found:", len(timestamps))

save_report(error_codes, ips, timestamps)
